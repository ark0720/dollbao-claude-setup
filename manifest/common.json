{
  "version": "1",
  "scope": "common",
  "_comment": "Phase 1 全員必裝清單。M1 骨架，M2 補完 verify_cmd / fallback_url / 確認 winget id。",
  "tools": [
    {
      "id": "OpenJS.NodeJS.LTS",
      "name": "Node.js LTS",
      "installer": "winget",
      "verify_cmd": "node --version",
      "fallback_url": "https://nodejs.org/",
      "required": true,
      "_todo_m2": "M2 確認 winget id 與 silent 安裝 flag"
    },
    {
      "id": "Git.Git",
      "name": "Git",
      "installer": "winget",
      "verify_cmd": "git --version",
      "fallback_url": "https://git-scm.com/",
      "required": true,
      "_todo_m2": "M2 確認 winget id"
    },
    {
      "id": "Google.CloudSDK",
      "name": "Google Cloud SDK (含 gcloud + bq CLI)",
      "installer": "winget",
      "verify_cmd": "gcloud --version",
      "fallback_url": "https://cloud.google.com/sdk/docs/install",
      "required": true,
      "_todo_m2": "M2 確認 winget id；驗證 bq CLI 是否同時裝上（gcloud bundle 應已含）"
    }
  ],
  "skill_bundles": [
    {
      "id": "gws",
      "source": "googleworkspace/cli",
      "lockfile": "skills-lock.json",
      "exclude_patterns": ["persona-*"],
      "install_helper": "scripts/helpers/install-gws-bundle.ps1"
    }
  ],
  "skills": [
    {
      "id": "dollbao-calendar",
      "path": "skills/dollbao-calendar"
    }
  ]
}
